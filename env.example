# Пример конфигурации для загрузки данных из S3 и настройки PostgreSQL
# Скопируйте этот файл в .env и заполните значениями
# 
# Для копирования выполните: cp env.example .env

# ============================================================================
# S3 конфигурация (для загрузки данных через bootstrap.py)
# Получите credentials у преподавателя
# ============================================================================
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=security-edu-data

# ============================================================================
# PostgreSQL конфигурация (для docker-compose)
# ============================================================================
DB_USER=analyst
DB_PASSWORD=security123
DB_NAME=security_logs
DB_HOST=localhost
DB_PORT=5432